



const mongoose = require('mongoose');
const cors = require('cors');
require('dotenv').config(); 

// 🔑 FIXED: Model imported cleanly at the top to prevent route execution crashes!
const Token = require('./models/Token'); 

const app = express();

// 1. Unlocked Security Gateways
app.use(cors({ origin: '*' }));
app.use(express.json());

// 2. Automated Database Link
const dbURI = process.env.MONGODB_URI; 
mongoose.connect(dbURI)
  .then(() => console.log('✅ Database connection established successfully!'))
  .catch((error) => console.log('⚠️ Running backend on local testing fallback pipeline.', error));

// ==========================================
// 🎯 DATA ROUTE ENDPOINTS
// ==========================================

// Test API Data Transmission Route
app.get('/api/status', (req, res) => {
  res.json({ message: "Hello from CampusPrint Backend Server!" });
});

// 🚀 ROUTE 1: Generate & Save New Tokens
app.post('/api/tokens/generate', async (req, res) => {
  try {
    const { totalPrice } = req.body;

    // Get current token count directly from your total database records
    const totalRecords = await Token.countDocuments({});
    const count = totalRecords + 1;

    // Your exact sequential token generation math 🎯
    const letterIndex = Math.floor((count - 1) / 999);
    const number = ((count - 1) % 999) + 1;
    const letter = String.fromCharCode(65 + letterIndex); // A, B, C...
    const tokenStr = `${letter}${String(number).padStart(3, "0")}`;

    // Save it securely to your global MongoDB Cloud Atlas
    const newToken = new Token({
      tokenNumber: tokenStr,
      totalPrice: totalPrice
    });
    await newToken.save();

    // Return it to your frontend app layout
    res.status(201).json(newToken);
  } catch (error) {
    console.error("Token database creation error:", error);
    res.status(500).json({ error: "Failed to generate server token sequence" });
  }
});

// 🚀 ROUTE 2: Fetch Single Token (Order Tracking Status Page)
app.get('/api/tokens/:number', async (req, res) => {
  try {
    const foundToken = await Token.findOne({ tokenNumber: req.params.number });
    
    if (!foundToken) {
      return res.status(404).json({ message: "Token reference entry not found." });
    }
    
    res.json(foundToken);
  } catch (error) {
    console.error("Database query error:", error);
    res.status(500).json({ error: "Server lookup operation failed." });
  }
});

// 🚀 ROUTE 3: Fetch ALL Tokens (Crucial for the Admin Dashboard)
app.get('/api/tokens/all', async (req, res) => {
  try {
    // Looks inside MongoDB, gets all documents, and sorts them newest first
    const allTokens = await Token.find({}).sort({ createdAt: -1 });
    res.json(allTokens);
  } catch (error) {
    console.error("Dashboard massive fetch error:", error);
    res.status(500).json({ error: "Failed to fetch admin dashboard records" });
  }
});

// 🚀 ROUTE 4: Update Token Status (So Admin can change 'Pending' to 'Completed')
app.patch('/api/tokens/:id/status', async (req, res) => {
  try {
    const { status } = req.body;
    const updatedToken = await Token.findByIdAndUpdate(
      req.params.id, 
      { status }, 
      { new: true } // Returns the newly modified data back to the dashboard instantly
    );
    res.json(updatedToken);
  } catch (error) {
    console.error("Status modify error:", error);
    res.status(500).json({ error: "Failed to update order processing status" });
  }
});

// ==========================================
// 🚀 3. PORT LISTENER ROOM (ALWAYS AT THE BOTTOM)
// ==========================================
const PORT = process.env.PORT || 8080;
app.listen(PORT, () => console.log(`🚀 Server booting cleanly on port ${PORT}`));
